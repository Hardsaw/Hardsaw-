{
  "version": 2,
  "builds": [
    {
      "src": "build.sh",
      "use": "@vercel/static-build",
      "config": { "distDir": "." }
    }
  ],
  "routes": [
    { "src": "/estimate", "dest": "/estimate.html" },
    { "src": "/estimate.html", "dest": "/estimate.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
