<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no"/>
<meta name="theme-color" content="#FFB800"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<title>Hardsaw · Governed Decision Engine</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow+Condensed:wght@300;400;600;700&display=swap');

:root {
  --black:   #080808;
  --panel:   #0E0E0E;
  --panel2:  #121212;
  --border:  #1E1E1E;
  --border2: #2A2A2A;
  --dim:     #333;
  --muted:   #555;
  --text:    #D8D0C0;
  --amber:   #FFB800;
  --amber2:  #CC9200;
  --green:   #00E87A;
  --red:     #FF3030;
  --blue:    #4A9EFF;
  --mono:    'Share Tech Mono', 'Courier New', monospace;
  --sans:    'Barlow Condensed', 'Courier New', monospace;
}

*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{background:var(--black);color:var(--text);font-family:var(--mono);min-height:100vh;display:flex;flex-direction:column;font-size:13px}
input,textarea,button,select{font-family:var(--mono);font-size:12px}
button{cursor:pointer;border:none;background:none}
textarea,input{outline:none}

/* ── SYSTEM RAIL ── */
.sys-rail {
  background:var(--panel);
  border-bottom:1px solid var(--border);
  display:flex;
  overflow-x:auto;
  scrollbar-width:none;
  padding:0 12px;
}
.sys-rail::-webkit-scrollbar{display:none}
.rail-step {
  display:flex;
  align-items:center;
  gap:6px;
  padding:8px 12px;
  white-space:nowrap;
  border-bottom:2px solid transparent;
  font-size:9px;
  letter-spacing:2px;
  color:var(--muted);
  transition:color 0.2s;
}
.rail-step.active{color:var(--amber);border-bottom-color:var(--amber)}
.rail-step.done{color:var(--green);border-bottom-color:var(--green)}
.rail-dot{width:5px;height:5px;border-radius:50%;background:currentColor;flex-shrink:0}
.rail-arrow{color:var(--border2);font-size:8px;margin:0 2px}

/* ── HEADER ── */
.hdr {
  background:var(--panel);
  border-bottom:2px solid var(--border2);
  padding:10px 14px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  position:sticky;
  top:0;
  z-index:200;
}
.brand { display:flex; align-items:baseline; gap:8px; }
.logo { font-family:var(--sans); font-size:22px; font-weight:700; letter-spacing:6px; color:var(--amber); }
.logo-sub { font-size:8px; color:var(--muted); letter-spacing:3px; }
.hdr-right { display:flex; align-items:center; gap:10px; }
.luna-chip {
  display:flex;align-items:center;gap:5px;
  font-size:8px;color:var(--muted);letter-spacing:2px;
  padding:4px 8px;border:1px solid var(--border2);border-radius:1px;
}
.luna-dot{width:5px;height:5px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}

/* ── GOVERNANCE PANEL ── */
.gov-panel {
  background:var(--panel);
  border-bottom:1px solid var(--border);
  padding:10px 14px;
}
.gov-grid {
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:1px;
  background:var(--border);
  border:1px solid var(--border);
}
.gov-cell {
  background:var(--panel2);
  padding:8px 10px;
}
.gov-k { font-size:7px; letter-spacing:2px; color:var(--muted); margin-bottom:3px; }
.gov-v { font-size:10px; color:var(--text); letter-spacing:1px; font-weight:bold; }
.gov-v.locked { color:var(--amber); }
.gov-v.green  { color:var(--green); }
.gov-v.red    { color:var(--red); }
.gov-v.dim    { color:var(--dim); }

/* ── BODY ── */
.body { flex:1; overflow-y:auto; }

/* ── INTAKE CANVAS ── */
.intake { padding:12px 14px; }

/* Evidence intake */
.evidence-grid {
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:4px;
  margin-bottom:12px;
}
.evidence-card {
  background:var(--panel2);
  border:1px solid var(--border2);
  padding:10px;
  position:relative;
  cursor:pointer;
  transition:border-color 0.15s;
}
.evidence-card:active{border-color:var(--amber)}
.evidence-card.has-data{border-color:var(--green)44}
.ev-type{font-size:8px;letter-spacing:3px;color:var(--muted);margin-bottom:4px}
.ev-status{font-size:10px;font-weight:bold;color:var(--dim)}
.ev-status.parsed{color:var(--green)}
.ev-status.conflict{color:var(--red)}
.ev-facts{font-size:8px;color:var(--muted);margin-top:2px}
.ev-icon{font-size:16px;margin-bottom:4px;display:block}

/* Spec section */
.section-hdr {
  font-size:8px;letter-spacing:4px;color:var(--muted);
  padding:8px 0 6px;
  border-bottom:1px solid var(--border);
  margin-bottom:10px;
  display:flex;justify-content:space-between;align-items:center;
}
.locked-badge {
  font-size:7px;color:var(--amber);letter-spacing:1px;
  padding:1px 5px;border:1px solid var(--amber)44;border-radius:1px;
}
.editable-badge {
  font-size:7px;color:var(--blue);letter-spacing:1px;
  padding:1px 5px;border:1px solid var(--blue)44;border-radius:1px;
}

.inp { width:100%;background:var(--panel2);border:1px solid var(--border2);color:var(--text);padding:9px 10px;border-radius:1px;font-size:13px;box-sizing:border-box; }
.inp:focus{border-color:var(--amber)}
.sel { width:100%;background:var(--panel2);border:1px solid var(--border2);color:var(--text);padding:9px 10px;border-radius:1px;font-size:12px;box-sizing:border-box;-webkit-appearance:none; }
.lbl { font-size:8px;letter-spacing:2px;color:var(--muted);margin-bottom:4px;display:block; }

.row2{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:8px}
.row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-bottom:8px}

/* Style note */
.style-note {
  font-size:9px;color:var(--muted);
  padding:6px 8px;
  background:var(--black);
  border-left:2px solid var(--amber);
  margin-bottom:8px;
  line-height:1.6;
}

/* Flag buttons */
.flag-grid{display:grid;grid-template-columns:1fr 1fr;gap:3px}
.flag-btn{background:var(--panel2);border:1px solid var(--border2);color:var(--dim);padding:7px 4px;font-size:8px;letter-spacing:1px;border-radius:1px;cursor:pointer;text-align:center;font-family:var(--mono);transition:all 0.15s}
.flag-btn.on{background:#FFB80011;border-color:var(--amber);color:var(--amber)}

/* ── STAGED SELECTOR ── */
.fam-btn{
  background:var(--panel2);border:1px solid var(--border2);
  color:var(--muted);padding:12px 8px;font-size:10px;letter-spacing:2px;
  border-radius:1px;cursor:pointer;text-align:center;
  font-family:var(--mono);transition:all 0.15s;width:100%;
}
.fam-btn.on{background:#FFB80018;border-color:var(--amber);border-left:3px solid var(--amber);color:var(--amber);font-weight:bold}
.fam-btn:active{opacity:0.7}

.ver-btn{
  background:var(--panel2);border:1px solid var(--border2);
  color:var(--dim);padding:11px 12px;font-size:11px;
  border-radius:1px;cursor:pointer;text-align:left;
  font-family:var(--mono);transition:all 0.15s;width:100%;
  display:flex;align-items:center;gap:8px;
}
.ver-btn.on{background:#FFB80011;border-color:var(--amber);color:var(--text)}
.ver-btn .ver-dot{width:6px;height:6px;border-radius:50%;background:var(--border2);flex-shrink:0;transition:background 0.15s}
.ver-btn.on .ver-dot{background:var(--amber)}
.ver-btn .ver-cal{margin-left:auto;font-size:7px;color:var(--green);letter-spacing:1px}
.ver-btn .ver-sub{font-size:8px;color:var(--muted);margin-top:2px;display:block}

.detail-row{margin-bottom:10px}
.detail-row .lbl{font-size:8px;letter-spacing:2px;color:var(--muted);margin-bottom:4px;display:block}

.confirm-line{display:flex;justify-content:space-between;padding:3px 0;font-size:9px;border-bottom:1px solid var(--border)}
.confirm-line .ck{color:var(--muted)}
.confirm-line .cv{color:var(--amber);font-weight:bold}
.confirm-line .cv.green{color:var(--green)}
.confirm-line .cv.dim{color:var(--dim)}

/* Scene builder */
.scene-hdr {
  display:flex;justify-content:space-between;align-items:center;
  margin-bottom:8px;
}
.lf-counter {
  font-size:9px;
  display:flex;gap:8px;align-items:center;
}
.lf-build{color:var(--amber);font-weight:bold}
.lf-opening{color:var(--blue)}

.edge-card {
  background:var(--panel2);
  border:1px solid var(--border2);
  border-radius:1px;
  padding:8px 10px;
  margin-bottom:4px;
}
.edge-card.fence-edge{border-left:2px solid var(--amber)}
.edge-card.opening-edge{border-left:2px solid var(--blue)}
.edge-row{display:flex;align-items:center;gap:6px}
.edge-label{font-size:8px;letter-spacing:2px;flex:1}
.edge-label.fence-lbl{color:var(--amber)}
.edge-label.opening-lbl{color:var(--blue)}
.edge-derived{font-size:9px;color:var(--dim);margin-top:4px;padding-top:4px;border-top:1px solid var(--border)}

/* Graph preview */
.graph-preview {
  background:var(--black);
  border:1px solid var(--border);
  padding:10px;
  margin-bottom:8px;
  font-size:9px;
}
.graph-title{font-size:8px;letter-spacing:3px;color:var(--muted);margin-bottom:8px}
.graph-row{display:flex;justify-content:space-between;padding:3px 0;border-bottom:1px solid var(--border);color:var(--dim)}
.graph-row .gv{color:var(--text);font-weight:bold}
.graph-row.highlight .gv{color:var(--amber)}

/* Truth bar */
.truth-bar {
  background:var(--black);
  border:1px solid var(--border2);
  border-top:2px solid var(--amber);
  padding:10px 12px;
  margin-bottom:8px;
}
.truth-title{font-size:7px;letter-spacing:4px;color:var(--amber);margin-bottom:8px}
.truth-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.truth-item .tk{font-size:7px;color:var(--muted);letter-spacing:1px;margin-bottom:2px}
.truth-item .tv{font-size:10px;color:var(--text)}
.truth-item .tv.locked{color:var(--amber)}
.unresolved{color:var(--red)!important}
.resolved{color:var(--green)!important}

.run-btn {
  width:100%;
  background:var(--amber);
  color:var(--black);
  padding:14px;
  font-size:11px;
  letter-spacing:4px;
  font-weight:bold;
  border-radius:1px;
  margin-top:4px;
  font-family:var(--sans);
}
.add-fence-btn{background:transparent;border:1px dashed var(--border2);color:var(--muted);padding:8px;font-size:8px;letter-spacing:2px;border-radius:1px;width:100%}
.add-gate-btn{background:transparent;border:1px dashed var(--blue)44;color:var(--blue);padding:8px;font-size:8px;letter-spacing:2px;border-radius:1px;width:100%}
.del-btn{background:transparent;border:1px solid var(--red)33;color:var(--red);padding:3px 7px;font-size:8px;border-radius:1px;cursor:pointer;flex-shrink:0}

/* ── THINKING ── */
.think {
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:60px 20px;min-height:60vh;
}
.think-engine {
  font-family:var(--sans);font-size:28px;font-weight:700;
  color:var(--amber);letter-spacing:6px;margin-bottom:20px;
}
.calc-list{list-style:none;text-align:left;width:100%;max-width:280px}
.calc-item{
  font-size:9px;letter-spacing:2px;color:var(--dim);
  padding:4px 0;border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:8px;
}
.calc-item.running{color:var(--amber);animation:blink 0.8s infinite}
.calc-item.done{color:var(--green)}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.3}}
.calc-dot{width:4px;height:4px;border-radius:50%;background:currentColor;flex-shrink:0}

/* ── RESULT ── */
.result-hdr{
  background:var(--panel);
  border-bottom:1px solid var(--border2);
  padding:10px 14px;
  position:sticky;
  top:0;
  z-index:150;
}
.result-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.readiness-badge{
  display:inline-flex;align-items:center;gap:6px;
  font-size:10px;letter-spacing:2px;font-weight:bold;
  padding:5px 10px;border-radius:1px;
}
.rdot{width:6px;height:6px;border-radius:50%;background:currentColor}
.result-meta{font-size:8px;color:var(--muted);letter-spacing:1px}
.hash-strip{font-size:8px;color:var(--dim);font-family:var(--mono)}

/* Dual output header */
.dual-hdr{
  display:grid;grid-template-columns:1fr 1fr;
  gap:1px;background:var(--border);
  border:1px solid var(--border);
  margin:10px 14px 0;
}
.dual-col{
  background:var(--panel2);
  padding:8px 10px;
  text-align:center;
}
.dual-col-title{font-size:8px;letter-spacing:3px;color:var(--muted);margin-bottom:2px}
.dual-col-val{font-size:11px;color:var(--text);font-weight:bold}
.dual-col.material-col{border-bottom:2px solid var(--amber)}
.dual-col.proof-col{border-bottom:2px solid var(--green)}

/* Tabs */
.tabs{display:flex;gap:1px;background:var(--border);margin:0 14px 12px;border:1px solid var(--border)}
.tab{flex:1;padding:9px 2px;background:var(--panel2);color:var(--muted);font-size:8px;letter-spacing:2px;cursor:pointer;text-align:center;border-bottom:2px solid transparent}
.tab.on{color:var(--amber);border-bottom-color:var(--amber)}

/* Result content */
.result-body{padding:0 14px 20px}

/* BOM */
.bom-head{display:grid;grid-template-columns:1fr 40px 50px;gap:4px;padding:5px 0 7px;border-bottom:1px solid var(--border2);font-size:7px;color:var(--dim);letter-spacing:2px}
.bom-row{display:grid;grid-template-columns:1fr 40px 50px;gap:4px;padding:7px 0;border-bottom:1px solid var(--border);font-size:11px;align-items:start}
.bom-sku{font-size:7px;color:var(--dim);margin-top:2px;letter-spacing:1px}
.bom-grp{font-size:7px;letter-spacing:3px;color:var(--muted);padding:8px 0 4px;margin-top:6px}

/* Proof */
.proof-row{display:flex;justify-content:space-between;align-items:start;padding:7px 0;border-bottom:1px solid var(--border)}
.proof-k{font-size:8px;color:var(--muted);letter-spacing:1px;flex:1}
.proof-v{font-size:11px;color:var(--green);font-weight:bold;text-align:right}
.proof-f{font-size:8px;color:var(--dim);margin-top:2px;text-align:right;word-break:break-word;max-width:180px}
.invariant-row{display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--border);font-size:9px}
.inv-pass{color:var(--green)}
.inv-fail{color:var(--red)}

/* Alerts */
.al-list{list-style:none;padding:0;margin:0}
.al-b{padding:7px 0;border-bottom:1px solid var(--border);font-size:11px;color:var(--red)}
.al-w{padding:7px 0;border-bottom:1px solid var(--border);font-size:11px;color:var(--amber)}

/* Packets */
.pkt-sec{margin-bottom:14px}
.pkt-hdr{font-size:7px;letter-spacing:3px;color:var(--muted);margin-bottom:6px;padding-bottom:5px;border-bottom:1px solid var(--border)}
.pkt-body{font-size:10px;line-height:1.9;color:var(--dim)}

/* Assist */
.assist-wrap{background:var(--panel2);border:1px solid var(--border2);border-left:2px solid var(--amber);margin-bottom:10px}
.assist-hdr{padding:7px 10px;border-bottom:1px solid var(--border);font-size:7px;letter-spacing:3px;color:var(--muted);display:flex;justify-content:space-between}
.assist-note{font-size:7px;color:var(--dim);font-style:italic}
.assist-body{padding:10px;min-height:50px;max-height:160px;overflow-y:auto}
.msg-a{margin-bottom:8px;font-size:12px;line-height:1.6;color:var(--text)}
.msg-u{margin-bottom:8px;font-size:12px;line-height:1.6;color:var(--dim)}
.role-a{font-size:7px;letter-spacing:2px;color:var(--amber);margin-bottom:2px}
.role-u{font-size:7px;letter-spacing:2px;color:var(--dim);margin-bottom:2px}
.assist-ir{display:flex;border-top:1px solid var(--border)}
.assist-in{flex:1;background:transparent;border:none;color:var(--text);font-size:12px;padding:9px 10px}
.assist-send{background:transparent;border:none;border-left:1px solid var(--border);color:var(--amber);font-size:18px;padding:0 12px;cursor:pointer}

/* Version panel */
.ver-panel{background:var(--black);border:1px solid var(--border);padding:10px;margin-bottom:10px}
.ver-title{font-size:7px;letter-spacing:3px;color:var(--muted);margin-bottom:8px}
.ver-row{display:flex;justify-content:space-between;padding:3px 0;border-bottom:1px solid var(--border);font-size:8px}
.ver-k{color:var(--dim)}
.ver-v{color:var(--text);font-size:8px}

/* Vault */
.vault-row{display:flex;gap:8px;padding:4px 0;border-bottom:1px solid var(--border);font-size:8px}

/* New job */
.new-job-btn{background:transparent;border:1px solid var(--border2);color:var(--muted);padding:8px 12px;font-size:8px;letter-spacing:2px;width:100%;margin-bottom:10px;border-radius:1px;cursor:pointer}

/* Luna log */
.luna-log-wrap{background:var(--black);border:1px solid var(--border);padding:10px;margin-top:10px}
.luna-row{display:flex;gap:10px;padding:4px 0;border-bottom:1px solid var(--border);font-size:8px}

.hidden{display:none!important}
.sect{margin-bottom:12px}
.hash-line{font-size:7px;color:var(--dim);margin-top:6px;word-break:break-all;line-height:1.6}
.calib-tag{font-size:7px;color:var(--green);letter-spacing:1px;margin-top:6px;padding:2px 6px;border:1px solid var(--green)33;border-radius:1px;display:inline-block}
</style>
</head>
<body>

<!-- ── HEADER ─────────────────────────────────────────────────────────────────── -->
<div class="hdr">
  <div class="brand">
    <div class="logo">HARDSAW</div>
    <div class="logo-sub">GOVERNED DECISION ENGINE</div>
  </div>
  <div class="hdr-right">
    <div class="luna-chip">
      <div class="luna-dot"></div>
      <span id="gc">LUNA · 0</span>
    </div>
  </div>
</div>

<!-- ── SYSTEM RAIL ─────────────────────────────────────────────────────────────── -->
<div class="sys-rail" id="sys-rail">
  <div class="rail-step active" id="rail-capture">
    <div class="rail-dot"></div>CAPTURE
  </div>
  <div class="rail-arrow">›</div>
  <div class="rail-step" id="rail-normalize">
    <div class="rail-dot"></div>NORMALIZE
  </div>
  <div class="rail-arrow">›</div>
  <div class="rail-step" id="rail-compute">
    <div class="rail-dot"></div>COMPUTE
  </div>
  <div class="rail-arrow">›</div>
  <div class="rail-step" id="rail-prove">
    <div class="rail-dot"></div>PROVE
  </div>
  <div class="rail-arrow">›</div>
  <div class="rail-step" id="rail-export">
    <div class="rail-dot"></div>EXPORT
  </div>
</div>

<!-- ── GOVERNANCE PANEL ────────────────────────────────────────────────────────── -->
<div class="gov-panel">
  <div class="gov-grid">
    <div class="gov-cell">
      <div class="gov-k">RULESET</div>
      <div class="gov-v locked" id="gv-ruleset">WP-TIGHT-v2.0</div>
    </div>
    <div class="gov-cell">
      <div class="gov-k">VENDOR PROFILE</div>
      <div class="gov-v locked" id="gv-vendor">AmeriFence</div>
    </div>
    <div class="gov-cell">
      <div class="gov-k">PROOF STATE</div>
      <div class="gov-v dim" id="gv-proof">AWAITING INPUT</div>
    </div>
    <div class="gov-cell">
      <div class="gov-k">READINESS</div>
      <div class="gov-v dim" id="gv-ready">—</div>
    </div>
  </div>
</div>

<!-- ── BODY ───────────────────────────────────────────────────────────────────── -->
<div class="body">

<!-- ═══ IDLE STAGE ═══ -->
<div id="s-idle">
<div class="intake">

  <!-- Evidence intake -->
  <div class="section-hdr" style="margin-bottom:8px">
    EVIDENCE INTAKE
    <span class="editable-badge">EDITABLE</span>
  </div>
  <input id="fi" type="file" accept="image/*" class="hidden" onchange="handleImg(this.files[0],'file')">
  <input id="fi-cam" type="file" accept="image/*" capture="environment" class="hidden" onchange="handleImg(this.files[0],'camera')">
  <div class="evidence-grid">
    <div class="evidence-card" id="ev-quote" onclick="document.getElementById('fi').click()">
      <span class="ev-icon">📄</span>
      <div class="ev-type">QUOTE</div>
      <div class="ev-status" id="ev-quote-st">MISSING</div>
      <div class="ev-facts" id="ev-quote-facts"></div>
    </div>
    <div class="evidence-card" id="ev-sketch" onclick="document.getElementById('fi-cam').click()">
