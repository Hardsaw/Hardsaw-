function renderChat(){
  var cb=document.getElementById('cb');if(!cb)return;
  cb.innerHTML=S.chat.map(function(m){
    return'<div class="'+(m.role==='assist'?'msg-a':'msg-u')+'"><div class="'+(m.role==='assist'?'role-a':'role-u')+'">'+(m.role==='assist'?'ASSIST — EXPLAIN RESULT':'YOU')+'</div>'+esc(m.text)+'</div>';
  }).join('')+(S.loading?'<div class="msg-a"><div class="role-a">ASSIST</div><span style="color:var(--muted)">thinking...</span></div>':'');
  cb.scrollTop=cb.scrollHeight;
}

function renderLog(){
  var lc=document.getElementById('lc'),ll=document.getElementById('ll');if(!lc||!ll)return;
  if(S.log.length){lc.classList.remove('hidden');ll.innerHTML=S.log.map(function(l){return'<div class="luna-row"><span style="color:'+(l.r==='ALLOWED'?'#00E87A':'#FF3030')+';min-width:60px">'+l.r+'</span><span style="color:var(--muted)">'+l.a+'</span></div>';}).join('');}
}

async function sendChat(){
  var inp=document.getElementById('ci');var msg=inp.value.trim();if(!msg||S.loading)return;
  inp.value='';S.loading=true;S.chat.push({role:'user',text:msg});renderChat();gate('assist_chat');
  var r=S.result;
  var reply=await claude('You are Assist in Hardsaw v3.1. Subordinate to compute. Explain, derive, compare — never estimate. 2-3 sentences. Contractor language.',
    'Job: '+r.style.label+' '+r.geo.buildLft+'lf, posts='+r.posts.totalPosts+', readiness='+r.rdy.st+'. Q: '+msg);
  S.loading=false;S.chat.push({role:'assist',text:reply});renderChat();
}

function setRailStep(id,state){
  var el=document.getElementById('rail-'+id);
  if(!el)return;
  el.className='rail-step'+(state==='active'?' active':state==='done'?' done':'');
}

function reset(){
  S={result:null,log:[],chat:[],tab:'BOM',loading:false};vault=[];extracted=null;
  document.getElementById('gc').textContent='LUNA · 0';
  document.getElementById('edges-container').innerHTML='';
  ['ends','corners','wg','dg','og'].forEach(function(id){
    var el=document.getElementById(id);if(el)el.value=id==='ends'?'2':'0';
  });
  document.querySelectorAll('.flag-btn.on').forEach(function(b){b.classList.remove('on');});
  document.getElementById('lc').classList.add('hidden');
  document.getElementById('up-wrap').classList.add('hidden');
  document.getElementById('ext-box').classList.add('hidden');
  // Reset evidence cards
  ['quote','sketch','site'].forEach(function(t){
    var st=document.getElementById('ev-'+t+'-st');var ft=document.getElementById('ev-'+t+'-facts');
    if(st){st.textContent='MISSING';st.className='ev-status';}if(ft)ft.textContent='';
  });
  // Reset rail
  ['capture','normalize','compute','prove','export'].forEach(function(id){setRailStep(id,'');});
  setRailStep('capture','active');
  // Reset gov panel
  document.getElementById('gv-proof').textContent='AWAITING INPUT';document.getElementById('gv-proof').className='gov-v dim';
  document.getElementById('gv-ready').textContent='—';document.getElementById('gv-ready').className='gov-v dim';
  edgeN=0;show('s-idle');addEdge('fence');
  // Reset staged selector to wood default
  document.querySelectorAll('.fam-btn').forEach(function(b){b.classList.toggle('on',b.dataset.fam==='wood');});
  _curFam='wood';renderVersions('wood');commitSelection();
}

function show(id){['s-idle','s-think','s-result'].forEach(function(s){var el=document.getElementById(s);if(el)el.classList.toggle('hidden',s!==id);});}
function sleep(ms){return new Promise(function(r){setTimeout(r,ms);});}
function esc(s){if(!s)return'';return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

// Init
addEdge('fence');
renderVersions('wood');   // boot with wood family
commitSelection();        // set initial confirm card
</script>
