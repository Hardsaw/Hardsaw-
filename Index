  setRailStep('capture','done');setRailStep('normalize','done');setRailStep('compute','active');
  show('s-think');
  S={result:null,log:[],chat:[],tab:'BOM',loading:false};vault=[];
  document.getElementById('gc').textContent='LUNA · 0';

  // Animate calculators
  var calcs=['A','B','C','D','E','F','G','H','I','J'];
  for(var ci=0;ci<calcs.length;ci++){
    var el=document.getElementById('calc-'+calcs[ci]);
    if(el)el.classList.add('running');
    await sleep(80);
    if(el)el.classList.remove('running');
    if(el)el.classList.add('done');
  }

  gate('normalize_spec');
  vadd('INTENT_CAPTURED',{styleId,ht,edges:edges.length,walks,drives});
  gate('run_calculator');

  var geo    = calcA(edges);
  var posts  = calcB(geo,ends,corners,walks,drives,others,rp.S);
  var conc   = calcF(posts,rp,style.family);
  var matR   = calcDEH(styleId,geo,posts,conc,ht);
  var rdy    = calcJ(geo,posts,matR,flags);
  var invars = buildProof(geo,posts,styleId);
  var invPass= Object.values(invars).every(Boolean);

  gate('check_readiness');vadd('READINESS_CHECKED',{st:rdy.st});
  gate('generate_packets');

  var sv=VERSIONS.styles[styleId]||{v:'UNKNOWN',cal:null,calDate:null};
  var famKey=style.family;
  var versions={
    coreEngineVersion: VERSIONS.coreEngine,
    familyRulepackVersion: VERSIONS.families[famKey]||'unknown',
    styleRulepackVersion:  sv.v,
    vendorProfileVersion:  VERSIONS.vendor,
    protocolVersion:       VERSIONS.protocol,
  };
  var outHash=H(JSON.stringify({geoHash:geo.geoHash,bom:matR.bom.map(function(i){return i.s+':'+i.qty;}),versions:versions}));
  vadd('PACKETS_GENERATED',{decisionId:outHash});

  S.result={geo,posts,conc,matR,rdy,invars,invPass,versions,styleId,style,sv,ht,flags,outHash};

  // Update governance panel
  document.getElementById('gv-ruleset').textContent=sv.v;
  document.getElementById('gv-proof').textContent=invPass?'ALL PASS':'FAILED';
  document.getElementById('gv-proof').className='gov-v '+(invPass?'green':'red');
  document.getElementById('gv-ready').textContent=rdy.st.replace('_',' ').toUpperCase();
  document.getElementById('gv-ready').className='gov-v '+(rdy.st==='ready'?'green':rdy.st==='needs_review'?'locked':'red');

  setRailStep('compute','done');setRailStep('prove','done');setRailStep('export','active');
  renderResultUI();show('s-result');

  gate('assist_chat');
  var sum=await claude(
    'You are Assist inside Hardsaw v3.1, a governed construction decision engine. '
    +'IMPORTANT: The engine computes and proves. You only explain. Never estimate. '
    +'Response rules: 2-3 sentences max, contractor-grade language, cite calibration source if present. '
    +'Assist actions available: explain result, explain warning, show derivation, compare to vendor quote.',
    style.label+': '+geo.buildLft+'lf build, '+geo.openingLft+'lf openings, '+ht+'ft, '
    +posts.totalPosts+' posts ('+posts.terminalPosts+' terminal, '+posts.linePosts+' line), '
    +posts.totalSecs+' sections, readiness='+rdy.st+', proof='+invPass
    +', calibration='+(sv.cal||'none')+', warnings='+(rdy.warn.length)
  );
  S.chat=[{role:'assist',text:sum}];renderChat();
}

// ── RENDER ────────────────────────────────────────────────────────────────────
var STC={ready:'var(--green)',needs_review:'var(--amber)',not_ready:'var(--red)'};
var STL={ready:'READY TO EXECUTE',needs_review:'NEEDS REVIEW',not_ready:'NOT READY'};

function renderResultUI(){
  var r=S.result,rdy=r.rdy,st=rdy.st;
  var badge=document.getElementById('readiness-badge');
  badge.style.color=STC[st];badge.style.borderColor=STC[st];badge.style.border='1px solid';
  document.getElementById('readiness-label').textContent=STL[st];
  document.getElementById('result-meta').textContent=
    r.style.label+' · '+r.ht+'ft · build '+r.geo.buildLft+'ft · openings '+r.geo.openingLft+'ft · '
    +r.posts.totalPosts+' posts · '+r.posts.totalSecs+' sections';
  document.getElementById('hash-strip').textContent='GEO: '+r.geo.geoHash+' · DECISION: '+r.outHash;
  document.getElementById('dual-mat').textContent=r.matR.bom.length+' items';
  var invCount=Object.values(r.invars).filter(Boolean).length+'/'+Object.values(r.invars).length;
  document.getElementById('dual-proof').textContent=invCount+' pass';
  setTab('BOM');renderLog();
}

function setTab(t){
  S.tab=t;
  ['BOM','PROOF','READY','PACKETS'].forEach(function(id){
    var el=document.getElementById('t-'+id);
    if(el)el.className='tab'+(id===t?' on':'');
  });
  renderTab();
}

function renderTab(){
  var t=S.tab,r=S.result,el=document.getElementById('tc');
