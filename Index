function buildProof(geo,posts,styleId){
  return{
    'hookups = 2×|E|':        posts.hookups===2*geo.fenceEdges.length,
    'terminal_posts = |V|':   posts.terminalPosts>=2,
    'line_posts ≥ 0':         posts.linePosts>=0,
    'build_length > 0':       geo.buildLft>0,
    'spacing locked':         posts.S===STYLES[styleId].rp.S,
    'geo hash deterministic': geo.geoHash.length===8,
  };
}

