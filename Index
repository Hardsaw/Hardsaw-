function H(s){var h=0;for(var i=0;i<s.length;i++)h=Math.imul(31,h)+s.charCodeAt(i)|0;return Math.abs(h).toString(16).padStart(8,'0').toUpperCase();}

// ── 10 CALCULATORS ────────────────────────────────────────────────────────────
function calcA(edges){
  var fe=edges.filter(function(e){return e.kind==='fence';});
  var oe=edges.filter(function(e){return e.kind==='opening';});
  var bL=fe.reduce(function(s,e){return s+e.length;},0);
  var oL=oe.reduce(function(s,e){return s+e.length;},0);
  return{fenceEdges:fe,openingEdges:oe,buildLft:bL,openingLft:oL,totalLft:bL+oL,geoHash:H(edges.map(function(e){return e.kind+':'+e.length;}).join('|')),F:{buildLft:fe.map(function(e){return e.length;}).join('+')||'0',openingLft:oe.map(function(e){return e.length;}).join('+')||'0'}};
}
function calcB(geo,ends,corners,walks,drives,others,S){
  var gp=(walks+drives+others)*2;
  var tp=ends+corners+gp;
  var lpArr=geo.fenceEdges.map(function(e){return Math.max(0,Math.ceil(e.length/S)-1);});
  var lp=lpArr.reduce(function(a,b){return a+b;},0);
  var secsArr=geo.fenceEdges.map(function(e){return Math.ceil(e.length/S);});
  var ts=secsArr.reduce(function(a,b){return a+b;},0);
  var hookups=2*geo.fenceEdges.length;
  return{terminalPosts:tp,linePosts:lp,gatePosts:gp,endPosts:ends,cornerPosts:corners,walkGates:walks,driveGates:drives,hookups:hookups,totalSecs:ts,lpArr:lpArr,secsArr:secsArr,S:S,totalPosts:tp+lp,F:{tp:ends+'(ends)+'+corners+'(corners)+'+(walks+drives+others)+'×2(gate)='+tp,lp:lpArr.map(function(v,i){return 'ceil('+geo.fenceEdges[i].length+'/'+S+')-1='+v;}).join(' + ')+'='+lp,hookups:'2×'+geo.fenceEdges.length+'='+hookups,secs:secsArr.map(function(v,i){return 'ceil('+geo.fenceEdges[i].length+'/'+S+')='+v;}).join(' + ')+'='+ts}};
}
function calcF(posts,rp,family){
  // Wood (all wood families): 1 bag per post — calibrated KAN004247 (wood) and KAN004303 (solid)
  if(family==='wood'){var b=posts.totalPosts*rp.con_line;return{totalBags:b,F:posts.totalPosts+'×1='+b+' [wood: 1/post calibrated KAN004247]'};}
  // Wood 8ft metal post: line×1 + terminal×2 — CONFIRMED KAN004244 (84×1+8×2=100 ✓)
  if(family==='wood_metal'){var b=Math.ceil(posts.linePosts*rp.con_line+posts.terminalPosts*rp.con_term);return{totalBags:b,F:posts.linePosts+'×1+'+posts.terminalPosts+'×2='+b+' [KAN004244 ✓]'};}
  // Chain link, ornamental, vinyl, farm: line×1 + terminal×2 (spec rule)
  var b=Math.ceil(posts.linePosts*rp.con_line+posts.terminalPosts*rp.con_term);
  return{totalBags:b,F:posts.linePosts+'×'+rp.con_line+'(line)+'+posts.terminalPosts+'×'+rp.con_term+'(terminal)='+b+' [spec]'};
}
function calcDEH(styleId,geo,posts,conc,ht){
  var style=STYLES[styleId],rp=style.rp,sk=style.skus,fam=style.family;
  var bom=[],warn=[],proof=[];
  function add(sku,qty,label,formula,grp){qty=Math.ceil(qty);if(qty<=0)return;bom.push({s:sku.s,u:sku.u,label:label||sku.d,qty:qty,formula:formula||'',group:grp||''});}
  function pf(k,v,f){proof.push({k:k,v:v,f:f});}
  var lf=geo.buildLft,tlf=geo.totalLft,tp=posts.terminalPosts,lp=posts.linePosts,ts=posts.totalSecs,walks=posts.walkGates,drives=posts.driveGates;

  if(fam==='wood'){
    // CALIBRATED: KAN004247 (tight cedar), KAN004304 (spaced), KAN004303 (solid board)
    var pk=rp.picket_fn==='floor'?Math.floor(tlf*rp.pickets_lf):rp.picket_fn==='round'?Math.round(tlf*rp.pickets_lf):Math.ceil(tlf*rp.pickets_lf);
    add(sk.picket,pk,sk.picket.d+' ('+sk.picket.s+')',rp.picket_fn+'('+tlf+'×'+rp.pickets_lf+')='+pk,'PICKETS');
    pf('Pickets',pk,rp.picket_fn+'('+tlf+'×'+rp.pickets_lf+')');
    add(sk.post,tp+lp,sk.post.d+' ('+sk.post.s+')',tp+'(T)+'+lp+'(L)='+(tp+lp),'POSTS');
    pf('Posts',tp+lp,tp+'T+'+lp+'L='+(tp+lp));
    var rl=ts*rp.rails_sec+walks*rp.walk_rb+drives*rp.drive_rb;
    add(sk.rail,rl,sk.rail.d+' ('+sk.rail.s+')',ts+'×'+rp.rails_sec+(walks?'+'+walks+'W×'+rp.walk_rb:'')+(drives?'+'+drives+'D×'+rp.drive_rb:'')+'='+rl,'RAILS');
    pf('Rails',rl,ts+'×'+rp.rails_sec+' + gate bonus');
    add(sk.con,conc.totalBags,'Concrete 60lb',conc.F,'CONCRETE');
    pf('Concrete',conc.totalBags,conc.F);
    if(walks>0){add(sk.hinge,walks,sk.hinge.d+' ('+sk.hinge.s+')',walks+'×1 pair','GATE HARDWARE');add(sk.latch,walks,sk.latch.d+' ('+sk.latch.s+')',walks+'×1 latch','GATE HARDWARE');}
    if(drives>0){add(sk.hinge,drives*2,sk.hinge.d+' ('+sk.hinge.s+')',drives+'×2 pairs','GATE HARDWARE');add(sk.latch,drives,sk.latch.d+' ('+sk.latch.s+')',drives+'×1','GATE HARDWARE');add(sk.rod,drives,sk.rod.d+' ('+sk.rod.s+')',drives+'×1','GATE HARDWARE');}

  } else if(fam==='wood_metal'){
    // CALIBRATED KAN004244: 695lf, 84 AFS line posts, 8 pipe terminals, 1650 pickets, 4-rail
    // Concrete: line×1 + terminal×2 = 100 ✓
    var pk2=rp.picket_fn==='round'?Math.round(tlf*rp.pickets_lf):Math.ceil(tlf*rp.pickets_lf);
    add(sk.picket,pk2,sk.picket.d+' ('+sk.picket.s+')',rp.picket_fn+'('+tlf+'×'+rp.pickets_lf+')='+pk2,'PICKETS');
    pf('Pickets',pk2,rp.picket_fn+'('+tlf+'×'+rp.pickets_lf+')');
    add(sk.lp,lp,sk.lp.d+' ('+sk.lp.s+')',lp+' line posts (AFS Forever Post)','LINE POSTS');
    add(sk.tp,tp,sk.tp.d+' ('+sk.tp.s+')',tp+' terminal/gate posts (Pipe 3×3)','TERMINAL POSTS');
    pf('Line posts',lp,posts.F.lp); pf('Terminal posts',tp,posts.F.tp);
    var rl2=ts*rp.rails_sec+walks*rp.walk_rb+drives*rp.drive_rb;
    add(sk.rail,rl2,sk.rail.d+' ('+sk.rail.s+')',ts+'×'+rp.rails_sec+' (4-rail 8ft fence)='+rl2,'RAILS');
    pf('Rails',rl2,ts+'×'+rp.rails_sec+' 4-rail system');
    add(sk.con,conc.totalBags,'Concrete 60lb',conc.F,'CONCRETE');
    pf('Concrete',conc.totalBags,'line×1+terminal×2 (KAN004244 ✓)');
    if(walks>0){add(sk.hinge,walks,sk.hinge.d+' ('+sk.hinge.s+')',walks+'×1 pair','GATE HARDWARE');add(sk.latch,walks,sk.latch.d+' ('+sk.latch.s+')',walks+'×1','GATE HARDWARE');}
    if(drives>0){add(sk.hinge,drives*2,sk.hinge.d+' ('+sk.hinge.s+')',drives+'×2 pairs','GATE HARDWARE');add(sk.latch,drives,sk.latch.d+' ('+sk.latch.s+')',drives+'×1','GATE HARDWARE');add(sk.rod,drives,sk.rod.d+' ('+sk.rod.s+')',drives+'×1','GATE HARDWARE');}

  } else if(fam==='chain_link'){
    var fabQ=Math.ceil((lf*1.02)/rp.fab_roll),railQ=Math.ceil(lf/rp.rail_stick)+1,twQ=Math.ceil(lf/100)+1,tieQ=Math.ceil(lf/10*3/50)+1;
    var bands=posts.endPosts*rp.bands_end+posts.cornerPosts*rp.bands_corner+posts.gatePosts*rp.bands_gate;
    add(sk.tp,tp,sk.tp.d,tp+' terminal posts','POSTS');
    add(sk.lp,lp,sk.lp.d,lp+' line posts','POSTS');
    pf('Terminal posts',tp,posts.F.tp); pf('Line posts',lp,posts.F.lp);
    add(sk.fab,fabQ,sk.fab.d,'ceil('+lf+'×1.02/'+rp.fab_roll+')='+fabQ+' rolls [build_length]','FABRIC');
    add(sk.rail,railQ,sk.rail.d,'ceil('+lf+'/'+rp.rail_stick+')+1='+railQ,'RAILS');
    add(sk.tw,twQ,sk.tw.d,'ceil('+lf+'/100)+1='+twQ,'WIRE');
    add(sk.tie,tieQ,sk.tie.d,tieQ+' bags','WIRE');
    add(sk.tb,bands,sk.tb.d,posts.endPosts+'×'+rp.bands_end+'(end)+'+posts.cornerPosts+'×'+rp.bands_corner+'(corner)+'+posts.gatePosts+'×'+rp.bands_gate+'(gate)='+bands,'HARDWARE');
    add(sk.re,posts.hookups,sk.re.d,'hookups='+posts.hookups,'HARDWARE');
    add(sk.con,conc.totalBags,'Concrete 60lb',conc.F,'CONCRETE');
    pf('Fabric rolls',fabQ,'ceil(buildLft×1.02/'+rp.fab_roll+')'); pf('Tension bands',bands,'spec formula');
    pf('Concrete',conc.totalBags,conc.F);
    if(walks>0)add(sk.wg,walks,sk.wg.d,walks+' walk','GATES');
    if(drives>0)add(sk.dg,drives,sk.dg.d,drives+' drive','GATES');

  } else if(fam==='ornamental'||fam==='ornamental_pool'){
    // PROVEN BRACKET FORMULAS from KAN005124 (165lf, 25 panels, 29 posts, 48 line, 60 universal):
    //   panels = ceil(lf/S) + corners + 1
    //   posts  = ceil(lf/S) + 1 + corners + gates×2
    //   line_brackets = panels×2 - 2
    //   universal_brackets = (posts+1)×2
    var S=rp.S||8;
    var orPanels=Math.ceil(lf/S)+posts.cornerPosts+1;
    var orPosts=Math.ceil(lf/S)+1+posts.cornerPosts+(walks+drives)*2;
    var lBrackets=Math.max(0,orPanels*2-2);
    var uBrackets=(orPosts+1)*2;
    var orCon=conc.totalBags;
    add(sk.panel,orPanels,sk.panel.d,'ceil('+lf+'/'+S+')+'+posts.cornerPosts+'corners+1='+orPanels,'PANELS');
    add(sk.post,orPosts,sk.post.d,'ceil('+lf+'/'+S+')+1+'+posts.cornerPosts+'C+'+(walks+drives)+'G×2='+orPosts,'POSTS');
    add(sk.cap,orPosts,sk.cap.d,orPosts+' caps (1 per post)','HARDWARE');
    add(sk.lbracket,lBrackets,sk.lbracket.d,'panels×2-2='+orPanels+'×2-2='+lBrackets,'HARDWARE');
    add(sk.ubracket,uBrackets,sk.ubracket.d,'(posts+1)×2=('+orPosts+'+1)×2='+uBrackets,'HARDWARE');
    add(sk.con,orCon,'Concrete 60lb',conc.F,'CONCRETE');
    pf('Panels',orPanels,'ceil(lf/S)+corners+1'); pf('Posts',orPosts,'ceil(lf/S)+1+C+G×2');
    pf('Line brackets',lBrackets,'panels×2-2 (KAN005124 ✓)'); pf('Universal brackets',uBrackets,'(posts+1)×2 (KAN005124 ✓)');
    if(fam==='ornamental_pool'){
      // Pool hardware: self-closing hinges + magna latch (KAN005124)
      if(walks+drives>0){
        var gateCount=walks+drives;
        add(sk.wg,gateCount,sk.wg.d,gateCount+' single swing gates','GATES');
        add(sk.hinge,gateCount,sk.hinge.d+' ('+sk.hinge.s+')',gateCount+' PR self-closing (pool)','GATE HARDWARE');
        add(sk.latch,gateCount,sk.latch.d+' ('+sk.latch.s+')',gateCount+' magna latch (pool)','GATE HARDWARE');
      }
      warn.push('Pool-code hardware: self-closing hinges (50383) · magna latch (50139) · verify AHJ requirements');
    } else {
      if(walks>0)add(sk.wg,walks,sk.wg.d,walks+' walk gate'+(walks>1?'s':''),'GATES');
      if(drives>0)add(sk.dg,drives,sk.dg.d,drives+' drive gate'+(drives>1?'s':''),'GATES');
    }

  } else if(fam==='vinyl'){
    var vPnl=ts+1,vPst=tp+lp,vCon=conc.totalBags;
    add(sk.panel,vPnl,sk.panel.d,ts+' sec+1','PANELS'); add(sk.post,vPst,sk.post.d,vPst+' posts','POSTS');
    add(sk.cap,vPst,sk.cap.d,vPst+' caps','HARDWARE'); add(sk.con,vCon,'Concrete 60lb',conc.F,'CONCRETE');
    if(walks>0)add(sk.wg,walks,sk.wg.d,walks+' walk','GATES');
    if(drives>0)add(sk.dg,drives,sk.dg.d,drives+' drive','GATES');

  } else if(fam==='farm'){
    var fPst=tp+lp,fCon=conc.totalBags;
    if(styleId==='farm.no_climb.horse'){add(sk.wire,Math.ceil(lf/100),sk.wire.d,'ceil('+lf+'/100)','WIRE');}
    else{add(sk.wire,Math.ceil(lf*(rp.strands||5)/1320),sk.wire.d,(rp.strands||5)+' strands','WIRE');}
    add(sk.post,fPst,sk.post.d,fPst+' posts','POSTS');
    add(sk.staple,Math.ceil(fPst*0.25),sk.staple.d,fPst+'×0.25lb','HARDWARE');
    add(sk.con,fCon,'Concrete 60lb',conc.F,'CONCRETE');
    if(walks>0)add(sk.wg,walks,sk.wg.d,walks+' walk','GATES');
    if(drives>0)add(sk.dg,drives,sk.dg.d,drives+' drive','GATES');
  }
  // Warnings
  var flags=Array.from(document.querySelectorAll('.flag-btn.on')).map(function(b){return b.dataset.flag;});
  if(flags.includes('HOA'))   warn.push('HOA — confirm approved style and color before ordering');
  if(flags.includes('rocky')) warn.push('Rocky soil — auger rental or blasting likely');
  if(flags.includes('grade')) warn.push('Sloped terrain — stepped or racked install required');
  if(flags.includes('permit'))warn.push('Permit required — obtain before scheduling crew');
  if(ht>8)                    warn.push('Height >8ft — permit likely required');
  if(geo.totalLft>1000)       warn.push('Large job — confirm phased delivery');
  if(STYLES[styleId].rp.pool) warn.push('Pool code compliant style — verify local AHJ requirements');
  return{bom,warn,proof};
}
function calcJ(geo,posts,matR,flags){
  var bl=[],warn=matR.warn.slice();
  if(geo.buildLft<1)bl.push('No fence runs entered');
  if(posts.totalPosts<2)bl.push('Post count error — check layout');
  if(flags.includes('permit'))bl.push('Permit required — obtain before scheduling crew');
  return{st:bl.length>0?'not_ready':warn.length>0?'needs_review':'ready',bl:bl,warn:warn};
}

