      h+='<div class="bom-row"><div><div>'+esc(i.label)+'</div><div class="bom-sku">'+esc(i.s)+'</div></div>'
        +'<div style="color:var(--amber);font-weight:bold;text-align:right">'+i.qty+'</div>'
        +'<div style="color:var(--dim)">'+i.u+'</div></div>';
    });
    // Geometry facts
    h+='<div style="margin-top:14px;padding-top:10px;border-top:1px solid var(--border2)">'
      +'<div style="font-size:7px;letter-spacing:3px;color:var(--muted);margin-bottom:8px">GEOMETRY FACTS</div>'
      +'<div style="display:grid;grid-template-columns:1fr 1fr;gap:6px">';
    [['BUILD LF',geo.buildLft+'ft'],['OPENING LF',geo.openingLft+'ft'],
     ['TERMINAL POSTS',posts.terminalPosts],['LINE POSTS',posts.linePosts],
     ['TOTAL POSTS',posts.totalPosts],['SECTIONS',posts.totalSecs],
     ['HOOKUPS',posts.hookups],['POST SPACING',posts.S+'ft O.C.']
    ].forEach(function(f){h+='<div><div style="font-size:7px;color:var(--muted);letter-spacing:1px">'+f[0]+'</div><div style="font-size:13px;font-weight:bold">'+f[1]+'</div></div>';});
    h+='</div></div>';
    // Version lineage
    h+='<div class="ver-panel" style="margin-top:10px"><div class="ver-title">VERSION LINEAGE — RuleVersionSet</div>';
    Object.entries(r.versions).forEach(function(e){h+='<div class="ver-row"><span class="ver-k">'+esc(e[0])+'</span><span class="ver-v">'+esc(e[1])+'</span></div>';});
    h+='</div>';
    if(r.sv.cal)h+='<div class="calib-tag">✓ CALIBRATED · AmeriFence '+r.sv.cal+' · '+r.sv.calDate+'</div>';
    h+='<div class="hash-line">GEO: '+geo.geoHash+' · DECISION: '+r.outHash+'<br>PROOF: '+(r.invPass?'✓ ALL INVARIANTS PASS':'✗ PROOF FAILED')+'</div>';
    el.innerHTML=h;

  } else if(t==='PROOF'){
    var h='<div style="font-size:7px;letter-spacing:3px;color:var(--muted);margin-bottom:10px">PROOF — EVERY VALUE TRACEABLE AND REPLAYABLE</div>';
    h+='<div style="font-size:7px;letter-spacing:2px;color:var(--muted);margin-bottom:6px">CALCULATOR A — GEOMETRY</div>';
    [{k:'build_length_ft',v:geo.buildLft+'ft',f:geo.F.buildLft+' ft (fence edges)'},
     {k:'opening_length_ft',v:geo.openingLft+'ft',f:geo.F.openingLft+' ft (gate edges)'},
     {k:'total_length_ft',v:geo.totalLft+'ft',f:geo.buildLft+' + '+geo.openingLft},
     {k:'geometry_hash',v:geo.geoHash,f:'H(edges)'},
    ].forEach(function(p){h+='<div class="proof-row"><div class="proof-k">'+esc(p.k)+'</div><div><div class="proof-v">'+esc(String(p.v))+'</div><div class="proof-f">'+esc(p.f)+'</div></div></div>';});

    h+='<div style="font-size:7px;letter-spacing:2px;color:var(--muted);margin:10px 0 6px">CALCULATOR B — POST LAYOUT</div>';
    [{k:'terminal_posts = |V|',v:posts.terminalPosts,f:posts.F.tp},
     {k:'line_posts = Σ ceil(L/S)−1',v:posts.linePosts,f:posts.F.lp},
     {k:'hookups = 2×|E|',v:posts.hookups,f:posts.F.hookups},
     {k:'total_sections',v:posts.totalSecs,f:posts.F.secs},
     {k:'post_spacing (S)',v:posts.S+'ft O.C.',f:'Locked rulepack '+r.style.rp.S+'ft'},
    ].forEach(function(p){h+='<div class="proof-row"><div class="proof-k">'+esc(p.k)+'</div><div><div class="proof-v">'+esc(String(p.v))+'</div><div class="proof-f">'+esc(p.f)+'</div></div></div>';});

    h+='<div style="font-size:7px;letter-spacing:2px;color:var(--muted);margin:10px 0 6px">INVARIANT CHECKS</div>';
    Object.entries(r.invars).forEach(function(e){
      h+='<div class="invariant-row"><span style="color:var(--muted);font-size:9px">'+esc(e[0])+'</span><span class="'+(e[1]?'inv-pass':'inv-fail')+'">'+(e[1]?'PASS':'FAIL')+'</span></div>';
    });

    h+='<div style="font-size:7px;letter-spacing:2px;color:var(--muted);margin:10px 0 6px">MATERIAL FORMULA TRACE</div>';
    matR.bom.forEach(function(i){
      h+='<div style="padding:5px 0;border-bottom:1px solid var(--border)"><div style="font-size:10px;color:var(--dim)">'+esc(i.label)+'</div><div style="font-size:8px;color:var(--dim);margin-top:2px">'+esc(i.formula)+' → '+i.qty+' '+i.u+'</div></div>';
    });
    h+='<div class="hash-line" style="margin-top:10px">GEO HASH: '+geo.geoHash+'<br>DECISION HASH: '+r.outHash+'</div>';
    el.innerHTML=h;

  } else if(t==='READY'){
    var st=rdy.st;
    var h='<div style="color:'+STC[st].replace('var(','').replace(')','').replace('--','#').replace('green','00E87A').replace('amber','FFB800').replace('red','FF3030')+';font-size:14px;font-weight:bold;margin-bottom:12px">'+STL[st]+'</div>';
    // Use CSS vars properly
    h='<div style="font-size:14px;font-weight:bold;margin-bottom:12px;color:'+
      (st==='ready'?'#00E87A':st==='needs_review'?'#FFB800':'#FF3030')+'">'+STL[st]+'</div>';
    if(rdy.bl.length){h+='<div class="bom-grp">BLOCKERS</div><ul class="al-list">'+rdy.bl.map(function(b){return'<li class="al-b">⛔ '+esc(b)+'</li>';}).join('')+'</ul>';}
    if(rdy.warn.length){h+='<div class="bom-grp">WARNINGS</div><ul class="al-list">'+rdy.warn.map(function(w){return'<li class="al-w">⚠ '+esc(w)+'</li>';}).join('')+'</ul>';}
    if(!rdy.bl.length&&!rdy.warn.length)h+='<div style="color:#00E87A">All checks passed. Clear to execute.</div>';
    h+='<div style="margin-top:12px;padding-top:10px;border-top:1px solid var(--border)">';
    h+='<div class="bom-grp">LOCKED PARAMETERS</div>';
    [['Rulepack',r.versions.styleRulepackVersion],['Vendor profile',r.versions.vendorProfileVersion],
     ['Post spacing',posts.S+'ft O.C.'],['Gate schema','opening edge deduction'],['Proof state',r.invPass?'ALL PASS':'FAILED']
    ].forEach(function(p){h+='<div class="proof-row"><div class="proof-k">'+p[0]+'</div><div class="proof-v" style="font-size:9px;color:var(--amber)">'+p[1]+'</div></div>';});
    h+='</div>';
    el.innerHTML=h;

  } else if(t==='PACKETS'){
    var oh=r.outHash;
    var h='<div class="pkt-sec"><div class="pkt-hdr">CONTRACTOR PACKET</div><div class="pkt-body">'
      +'Job: '+oh+'<br>'+r.style.label+' · '+r.ht+'ft<br>'
      +'Build: '+geo.buildLft+'ft · Openings: '+geo.openingLft+'ft<br>'
      +'Posts: '+posts.totalPosts+' ('+posts.terminalPosts+' terminal, '+posts.linePosts+' line)<br>'
      +'Sections: '+posts.totalSecs+' · '+posts.S+'ft O.C. · Gates: '+posts.walkGates+'W/'+posts.driveGates+'D<br>'
      +'Status: '+rdy.st.replace('_',' ').toUpperCase()
      +'</div></div>';
    h+='<div class="pkt-sec"><div class="pkt-hdr">SUPPLIER PACKET (PO DRAFT)</div><div class="pkt-body">'
      +'PO: '+oh+'<br>'+matR.bom.map(function(i){return i.qty+'× '+i.s+' ('+i.u+')';}).join('<br>')+'</div></div>';
    h+='<div class="pkt-sec"><div class="pkt-hdr">DECISION RECORD — DecisionResult</div><div class="pkt-body" style="font-size:9px">'
      +'decisionId: '+oh+'<br>familyId: '+r.style.family+'<br>styleId: '+r.styleId+'<br>'
      +Object.entries(r.versions).map(function(e){return esc(e[0])+': '+esc(e[1]);}).join('<br>')+'</div></div>';
    h+='<div class="pkt-sec"><div class="pkt-hdr">LIFEVAULT — APPEND-ONLY CHAIN</div><div class="pkt-body" style="font-size:9px">'
      +vault.map(function(e){return'<div style="display:flex;gap:8px;padding:2px 0;border-bottom:1px solid var(--border)"><span style="color:var(--amber);min-width:130px">'+e.t+'</span><span style="color:var(--dim)">'+e.h+'</span></div>';}).join('')+'</div></div>';
