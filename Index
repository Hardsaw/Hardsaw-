    var h='<div style="font-size:7px;letter-spacing:3px;color:var(--muted);margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid var(--border)">QUANTITIES ONLY — PRICING DEFERRED</div>';
    var lastGrp='';
    h+='<div class="bom-head"><span>ITEM / SKU</span><span style="text-align:right">QTY</span><span>UNIT</span></div>';
